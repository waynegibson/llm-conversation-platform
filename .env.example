POSTGRES_USER=llm_app
POSTGRES_PASSWORD=change_me_securely
POSTGRES_DB=llm_platform
POSTGRES_PORT=15450
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

APP_ENV=development
LOG_LEVEL=INFO
METRICS_ENABLED=true

# Host path where Ollama model files are stored on your external SSD
OLLAMA_MODELS_PATH=/Volumes/SSDSCX_DATA/ollama/models

# API runtime settings
APP_HOST=0.0.0.0
APP_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT_SECONDS=120
REQUEST_TIMEOUT_SECONDS=60
